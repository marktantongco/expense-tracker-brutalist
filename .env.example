# Vercel Environment Variables (for local development)
# These should be set in GitHub Secrets for CI/CD

# Get these from: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

# Get these from: .vercel/project.json after running `vercel link`
VERCEL_ORG_ID=your_org_id_here
VERCEL_PROJECT_ID=your_project_id_here
